# Copy this file to .env before running scripts/run_dialect_demo.sh.
# Do not commit real API keys.

KRALAPI_BASE_URL=https://kralapi.kralai.tech
KRALAPI_MODEL=gpt-5.5
KRALAPI_API_KEY=

# Remote data disk mount root. The demo script derives model/cache paths from it
# when the more specific variables below are left empty.
DATA_ROOT=/root/autodl-tmp

# Put downloaded VoxCPM2 weights under $DATA_ROOT/models/VoxCPM2 by default.
# Override only when the model lives elsewhere.
# VOXCPM_MODEL_PATH=/custom/path/to/VoxCPM2

# Demo launch defaults. Override in the shell if needed:
# PORT=8810 DEVICE=auto scripts/run_dialect_demo.sh
HOST=0.0.0.0
PORT=8808
DEVICE=cuda

# Optional Python executable. The launcher auto-detects .venv, active conda,
# and $DATA_ROOT/conda-envs/voxcpm before falling back to system Python.
# PYTHON_BIN=$DATA_ROOT/conda-envs/voxcpm/bin/python

# Optional cache locations for large downloads. Defaults:
# HF_HOME=$DATA_ROOT/cache/hf
# MODELSCOPE_CACHE=$DATA_ROOT/cache/modelscope
# TORCH_HOME=$DATA_ROOT/cache/torch
# HF_HOME=/custom/path/to/cache/hf
# MODELSCOPE_CACHE=/custom/path/to/cache/modelscope
# TORCH_HOME=/custom/path/to/cache/torch

# Optional saved UI preset storage. Defaults to $DATA_ROOT/presets.
# VOXCPM_PRESETS_DIR=/custom/path/to/presets
