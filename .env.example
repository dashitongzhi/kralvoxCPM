# Copy this file to .env or source the variables in your shell before starting app.py.
# Do not commit real API keys.

KRALAPI_BASE_URL=https://kralapi.kralai.tech
KRALAPI_MODEL=gpt-5.5
KRALAPI_API_KEY=

# Put downloaded VoxCPM2 weights on the target machine and pass this path to app.py.
VOXCPM_MODEL_PATH=/path/to/VoxCPM2

# Optional cache locations for large downloads.
HF_HOME=/path/to/cache/hf
MODELSCOPE_CACHE=/path/to/cache/modelscope
TORCH_HOME=/path/to/cache/torch
